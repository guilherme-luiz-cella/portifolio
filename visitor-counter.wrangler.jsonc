{
  "name": "portfolio-visitor-counter",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/workers/visitor-counter.ts",
  "kv_namespaces": [
    {
      "binding": "VISITOR_COUNT",
